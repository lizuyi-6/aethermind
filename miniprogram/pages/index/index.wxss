/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 40px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, #1a1a1a 0%, #2a2a2a 100%);
}

.welcome-section {
  text-align: center;
  margin-bottom: 60px;
}

.welcome-icon {
  font-size: 80px;
  margin-bottom: 20px;
}

.welcome-title {
  font-size: 32px;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16px;
}

.welcome-desc {
  font-size: 16px;
  color: #999999;
  line-height: 1.6;
}

.suggestions-section {
  width: 100%;
  max-width: 600px;
  margin-bottom: 40px;
}

.suggestions-title {
  font-size: 18px;
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 20px;
  text-align: center;
}

.suggestions-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.suggestion-item {
  background-color: #2a2a2a;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: all 0.3s;
  border: 1px solid transparent;
}

.suggestion-item:active {
  background-color: #333333;
  border-color: #4CAF50;
}

.suggestion-icon {
  font-size: 24px;
}

.suggestion-text {
  font-size: 16px;
  color: #ffffff;
  flex: 1;
}

.action-section {
  width: 100%;
  max-width: 600px;
  margin-top: auto;
  padding-top: 40px;
}

.start-btn {
  width: 100%;
  height: 50px;
  line-height: 50px;
  background-color: #4CAF50;
  color: white;
  border-radius: 12px;
  font-size: 18px;
  font-weight: 500;
}

.start-btn:active {
  background-color: #45a049;
}

